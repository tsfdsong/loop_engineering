{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://loopengine.local/schemas/handoff-schema.json",
  "title": "go Handoff Schema",
  "description": "Phase-to-phase structured context handoff used by go between skill nodes in a DAG.",
  "type": "object",
  "required": [
    "phase",
    "scope_applied",
    "findings_summary",
    "next_phase_hint"
  ],
  "additionalProperties": false,
  "properties": {
    "phase": {
      "type": "string",
      "enum": [
        "system-review",
        "code-reviewer",
        "clean-code",
        "brainstorming",
        "writing-plans",
        "systematic-debugging",
        "verification-before-completion",
        "evidence-first",
        "agent-browser",
        "web-regression-e2e",
        "web-visual-diff",
        "web-audit-a11y",
        "web-perf-budget",
        "dispatching-parallel-agents"
      ],
      "description": "Skill/phase that produced this handoff. Must be a registered go action executor."
    },
    "scope_applied": {
      "type": "string",
      "enum": [
        "full_project",
        "diff_only",
        "module",
        "file",
        "external_url",
        "web_url_set"
      ],
      "description": "Effective scope level used by the phase (matches Intent Schema scope_level). web_url_set covers multi-URL web_qa audits."
    },
    "hotspot_modules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Module/file paths identified as high-priority for downstream phases. May be empty.",
      "default": []
    },
    "findings_summary": {
      "type": "object",
      "required": ["critical", "important", "minor"],
      "additionalProperties": false,
      "properties": {
        "critical": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of critical-severity findings."
        },
        "important": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of important-severity findings."
        },
        "minor": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of minor-severity findings."
        }
      },
      "description": "Severity-bucketed finding counts produced by this phase."
    },
    "top_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "important", "minor"]
          },
          "module": { "type": "string" }
        }
      },
      "description": "Top issues (most material) the next phase should focus on.",
      "default": []
    },
    "web_qa_findings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "e2e_failures": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Count of failing E2E regression tests (web-regression-e2e output)."
        },
        "a11y_violations": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "critical": { "type": "integer", "minimum": 0, "default": 0 },
            "serious": { "type": "integer", "minimum": 0, "default": 0 },
            "moderate": { "type": "integer", "minimum": 0, "default": 0 },
            "minor": { "type": "integer", "minimum": 0, "default": 0 }
          },
          "description": "axe-core severity bucketed counts (web-audit-a11y output)."
        },
        "visual_diffs": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Count of pages with visual regressions (web-visual-diff output)."
        },
        "perf_regressions": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Count of metrics breaching perf budget (web-perf-budget output)."
        }
      },
      "description": "Structured aggregation of web_qa family fan-out outputs. Consumed by synthesize_findings and downstream combination families (web_qa_then_debug_fix / web_qa_then_refactor). Optional; present only for web_qa phase handoffs.",
      "default": {}
    },
    "next_phase_hint": {
      "type": "string",
      "minLength": 1,
      "description": "Free-text hint for the next phase: scope to focus, modules to deep-dive, or actions to avoid."
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["report", "patch", "test_result", "trace", "plan", "screenshot", "metric"]
          },
          "path": { "type": "string" },
          "summary": { "type": "string" }
        }
      },
      "description": "Concrete artifact paths produced by this phase (reports, patches, traces, etc.).",
      "default": []
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Phase-level confidence (0.0-1.0). Optional but recommended for synthesis nodes."
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Wall-clock duration in milliseconds. Optional."
    }
  }
}
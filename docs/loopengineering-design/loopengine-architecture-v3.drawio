        <mxCell id="hub_router" value="Skill 工具加载&#xa;&#xa;每次只加载一个技能&#xa;语义兜底优先&#xa;MCP 工具优先于 Read" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=11;align=center;" vertex="1" parent="hub">
          <mxGeometry x="370" y="60" width="280" height="140" as="geometry" />
        </mxCell>
        <mxCell id="hub_categories" value="7 大类别 (56 技能 + 3 跨插件)&#xa;&#xa;📝 编码 5 · 🏗️ 架构 7 · 🔧 重构 4&#xa;🧪 测试 3 · 🐛 调试 1 · 🔌 API 3&#xa;🔐 安全 2 · 📄 文档 2 (含 docx/pdf¹)&#xa;🔍 审查 4 (含 system-review) · ✅ 验证 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="hub">

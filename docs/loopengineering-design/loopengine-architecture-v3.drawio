        <mxCell id="hub_intent" value="意图识别&#xa;&#xa;关键词表 57 行&#xa;语义兜底 5 级&#xa;冲突裁决 N 个" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1565c0;fontSize=11;align=center;" vertex="1" parent="hub">
          <mxGeometry x="40" y="60" width="280" height="140" as="geometry" />

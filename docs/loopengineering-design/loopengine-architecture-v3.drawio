        <!-- Layer 3: loop -->
        <mxCell id="loop" value="" style="swimlane;startSize=40;fillColor=#e8f5e9;strokeColor=#2e7d32;strokeWidth=3;rounded=1;swimlaneFillColor=#e8f5e9;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="810" width="1840" height="240" as="geometry" />
        </mxCell>
        <mxCell id="loop_title" value="🔄 Layer 3 · loop v4.1 · 闭环执行器 (0 Python · 自包含)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#1b5e20;" vertex="1" parent="loop">
          <mxGeometry x="0" y="0" width="1840" height="40" as="geometry" />
        </mxCell>
        <mxCell id="loop_modes" value="🎛️ 4 种模式&#xa;&#xa;--auto (go 固定调用)&#xa;--lite (轻量)&#xa;--standard (标准)&#xa;--full (完整)&#xa;&#xa;默认自适应" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="loop">
          <mxGeometry x="20" y="55" width="220" height="170" as="geometry" />
        </mxCell>
        <mxCell id="loop_gates" value="🚪 门禁矩阵&#xa;&#xa;G0 预检 · G1 需求 · G2 计划&#xa;G3 实现 · G4 自测 · G5 集成&#xa;G6 验收 · G7 文档 · G8 归档&#xa;G9 代码审查 (代码层)&#xa;F1-F5 前端验证&#xa;G10 系统审查 (go 调用，不重复)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="loop">
          <mxGeometry x="260" y="55" width="320" height="170" as="geometry" />
        </mxCell>
        <mxCell id="loop_selfheal" value="🩹 自愈闭环&#xa;&#xa;A 阻塞 (3次修复失败→升级)&#xa;B 警告 (提示建议)&#xa;C 信息 (自动跳过)&#xa;🎨 实验 (受控试错)&#xa;exhausted 终态保护" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="loop">
          <mxGeometry x="600" y="55" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="loop_state" value="💾 状态与协议&#xa;&#xa;• .loop-state-*.json&#xa;• mode-auto.md · gate-matrix.md&#xa;• experience-library.md&#xa;• self-healing.md&#xa;• state-protocol.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="loop">
          <mxGeometry x="900" y="55" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="loop_principles" value="⚖️ 10 大原则&#xa;&#xa;1. 断点续跑&#xa;2. 门禁不可跳过&#xa;3. 不降级红线&#xa;4. worktree 隔离&#xa;5. 验证证据化&#xa;6. 每轮报告&#xa;7. 自动 commit (G9 必过)&#xa;8. G10 不在 loop 重复&#xa;9. 合并需确认 (--auto除外)&#xa;10. MCP 优先于 Read" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="loop">
          <mxGeometry x="1200" y="55" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="loop_frontend" value="🖥️ 前端验证&#xa;&#xa;F1-F5 维度&#xa;check-agent-browser.sh G0&#xa;agent-browser MCP&#xa;playwright/headroom" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#2e7d32;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="loop">
          <mxGeometry x="1500" y="55" width="320" height="170" as="geometry" />
        </mxCell>

        <!-- 横切关注点 -->

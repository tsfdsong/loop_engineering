        </mxCell>
        <mxCell id="go_title" value="🎯 Layer 2 · go v4.0 · 编排器 (5 模块 · Python)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#e65100;" vertex="1" parent="go">
          <mxGeometry x="0" y="0" width="1840" height="40" as="geometry" />
        </mxCell>
        <mxCell id="go_steps" value="📋 Step 流程&#xa;&#xa;⓪ 评估 L1/L2/L3&#xa;① 需求分析&#xa;② 方案推荐&#xa;③ 拆分任务 (调 ZCode)&#xa;④ 创建 worktree&#xa;⑤ 并发执行 (ThreadPool)&#xa;⑥ 上下文交接&#xa;⑦ 门禁验证&#xa;⑦.5 G10 系统审查&#xa;⑧ 合并+交付" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57f17;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="go">
          <mxGeometry x="20" y="55" width="220" height="215" as="geometry" />
        </mxCell>
        <mxCell id="go_modules" value="🐍 5 个 Python 模块&#xa;&#xa;orchestrator.py (主调度)&#xa;  └─ 253 行 · orchestrate()&#xa;complexity_evaluator.py&#xa;  └─ 纯规则 L0 分流 (零 token)&#xa;zcode_runner.py&#xa;  └─ 调 ZCode CLI · 重试 · 降级&#xa;state_manager.py&#xa;  └─ atomic_update + 全局锁&#xa;git_ops.py&#xa;  └─ worktree + 分支 + commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffecb3;strokeColor=#f57f17;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="go">
          <mxGeometry x="260" y="55" width="320" height="215" as="geometry" />
        </mxCell>
        <mxCell id="go_concurrency" value="⚡ 并发机制&#xa;&#xa;• ThreadPoolExecutor + subprocess&#xa;• 每个子任务独立 worktree (go-xxx)&#xa;• per-task model 路由&#xa;• 文件锁避免 Windows 抢占&#xa;• _global_locks 串行化 config.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffecb3;strokeColor=#f57f17;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="go">
          <mxGeometry x="600" y="55" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="go_prompt" value="📝 build_prompt&#xa;&#xa;• 注入 _get_repomix_structure&#xa;  (Python 层打包任务文件)&#xa;• 8000 字符截断&#xa;• 替换无效的 MCP 提示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c8e6c9;strokeColor=#388e3c;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="go">
          <mxGeometry x="600" y="170" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="go_state" value="💾 状态管理&#xa;&#xa;• .orchestrate-state.json&#xa;• atomic_update(项目目录, 更新函数)&#xa;• _global_locks[project_dir]&#xa;• 重入安全 · 跨线程原子" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffecb3;strokeColor=#f57f17;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="go">
          <mxGeometry x="900" y="55" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="go_retry" value="🔁 重试 + 降级&#xa;&#xa;• _detect_degradation()&#xa;  → 429 / quota_exceeded&#xa;• call_zcode_with_retry()&#xa;  → MAX_RETRIES=2&#xa;• degraded_trigger 字段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffecb3;strokeColor=#f57f17;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="go">
          <mxGeometry x="900" y="170" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="go_g10" value="🔍 ⑦.5 G10 系统审查&#xa;&#xa;调用 system-review 技能:&#xa;1. 横向自洽性 (跨技能一致性)&#xa;2. 纵向架构深度 (3 层)&#xa;3. 持续改进 (P0/P1/P2)&#xa;gate-matrix.md 不重复触发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcdd2;strokeColor=#c62828;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="go">
          <mxGeometry x="1200" y="55" width="320" height="215" as="geometry" />
        </mxCell>
        <mxCell id="go_routing" value="⚙️ 配置&#xa;&#xa;routing-rules.yaml&#xa;  ├ zcode_cli (未应用)&#xa;  ├ worktree (未应用)&#xa;  └ retry (部分应用)&#xa;⚠️ 配置脱节 (待修复)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe0b2;strokeColor=#ef6c00;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=2;" vertex="1" parent="go">
          <mxGeometry x="1540" y="55" width="280" height="215" as="geometry" />
        </mxCell>

        <mxCell id="arrow_go_loop" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#f57f17;strokeWidth=3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="go" target="loop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="go_loop_label" value="go → ZCode CLI → loop --auto (经 ZCode prompt 注入)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontStyle=1;fontColor=#f57f17;" vertex="1" parent="1">
          <mxGeometry x="700" y="775" width="600" height="20" as="geometry" />

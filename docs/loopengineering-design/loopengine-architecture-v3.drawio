        <!-- Layer 2: go -->
        <mxCell id="go" value="" style="swimlane;startSize=40;fillColor=#fff8e1;strokeColor=#f57f17;strokeWidth=3;rounded=1;swimlaneFillColor=#fff8e1;fontSize=12;fontStyle=1;" vertex="1" parent="1">

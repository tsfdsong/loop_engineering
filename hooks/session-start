#!/usr/bin/env bash
# SessionStart hook for loopengine plugin (Claude Code / Cursor / Copilot)
# Bootstrap: injects orch v2 (natural-language-first multi-skill orchestrator) at session start
# 公共逻辑见 hooks/_lib.sh

set -euo pipefail

# shellcheck source=_lib.sh
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"

orch_content=$(load_orch_runtime_bundle "$PLUGIN_ROOT")
lessons_content=$(load_recent_lessons "$PLUGIN_ROOT")
session_context=$(build_session_context "$orch_content" "$lessons_content")
emit_session_start_json "$session_context"
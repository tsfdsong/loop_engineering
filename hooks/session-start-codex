#!/usr/bin/env bash
# SessionStart hook for loopengine plugin (Codex variant)
# Bootstrap: injects skill-hub as the skill discovery/routing layer

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read skill-hub content (replaces using-superpowers as the bootstrap skill)
skill_hub_content=$(cat "${PLUGIN_ROOT}/skills/skill-hub/SKILL.md" 2>&1 || echo "Error reading skill-hub skill")

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_hub_escaped=$(escape_for_json "$skill_hub_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have LoopEngine — the full-stack development engine with 55 skills.\n\n**Below is the full content of your 'loopengine:skill-hub' skill — your skill routing hub. For all other skills, use the 'Skill' tool:**\n\n${skill_hub_escaped}\n</EXTREMELY_IMPORTANT>"

# Codex-specific format
printf '{\n  "additionalContext": "%s"\n}\n' "$session_context" | cat

exit 0
